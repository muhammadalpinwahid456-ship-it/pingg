{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        ".validate": "newData.hasChildren(['fullname', 'email', 'createdAt'])",
        "fullname": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().contains('@')"
        },
        "createdAt": {
          ".validate": "newData.isString()"
        },
        "photoURL": {
          ".validate": "newData.isString()"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 150"
        }
      }
    },
    "reels": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$reelId": {
        ".validate": "newData.hasChildren(['userId', 'userName', 'caption', 'mediaUrl', 'mediaType', 'timestamp']) && newData.child('userId').val() === auth.uid",
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "caption": {
          ".validate": "newData.isString() && newData.val().length <= 300"
        },
        "mediaUrl": {
          ".validate": "newData.isString()"
        },
        "mediaType": {
          ".validate": "newData.isString() && (newData.val() === 'image' || newData.val() === 'video')"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "likes": {
          "$userId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "comments": {
          "$commentId": {
            ".validate": "newData.hasChildren(['userName', 'userPhoto', 'text', 'timestamp'])",
            "userName": {
              ".validate": "newData.isString()"
            },
            "userPhoto": {
              ".validate": "newData.isString()"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            }
          }
        }
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChild('messages')",
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'senderName', 'text', 'timestamp']) && newData.child('timestamp').isNumber() && newData.child('text').isString() && newData.child('text').val().length > 0",
            "senderId": {
              ".validate": "newData.isString() && auth.uid === newData.val()"
            },
            "senderName": {
              ".validate": "newData.isString()"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            }
          }
        }
      }
    }
  }
}
