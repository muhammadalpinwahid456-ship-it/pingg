{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        ".validate": "data.exists() ? (newData.hasChildren(['fullname', 'email']) || newData.child('photoURL').exists() || newData.child('description').exists()) : newData.hasChildren(['fullname', 'email'])",
        "fullname": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().contains('@')"
        },
        "createdAt": {
          ".validate": "newData.isString()"
        },
        "photoURL": {
          ".validate": "newData.isString()"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 150"
        }
      }
    },
    "reels": {
      ".read": "auth != null",
      "$reelId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "userId": {
          ".validate": "newData.isString()"
        },
        "userName": {
          ".validate": "newData.isString()"
        },
        "userPhoto": {
          ".validate": "newData.isString()"
        },
        "caption": {
          ".validate": "newData.isString() && newData.val().length <= 300"
        },
        "mediaUrl": {
          ".validate": "newData.isString()"
        },
        "mediaType": {
          ".validate": "newData.isString() && (newData.val() === 'image' || newData.val() === 'video')"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        },
        "cloudinaryPublicId": {
          ".validate": "newData.isString()"
        },
        "likes": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$userId": {
            ".validate": "newData.isBoolean() && $userId === auth.uid"
          }
        },
        "comments": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$commentId": {
            ".validate": "newData.hasChildren(['userName', 'userPhoto', 'text', 'timestamp', 'userId']) && newData.child('userId').val() === auth.uid",
            "userName": {
              ".validate": "newData.isString() && newData.val().length > 0"
            },
            "userPhoto": {
              ".validate": "newData.isString()"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "userId": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            }
          }
        }
      }
    },
    "chats": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "messages": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'senderName', 'text', 'timestamp']) && newData.child('senderId').val() === auth.uid",
            "senderId": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            },
            "senderName": {
              ".validate": "newData.isString() && newData.val().length > 0"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "isRead": {
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    }
  }
}
